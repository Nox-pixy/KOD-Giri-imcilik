<!-- Arka Plan Karartması -->
<div class="overlay" id="overlay"></div>

<!-- Giriş Yap Çekmecesi -->
<div class="drawer" id="loginDrawer">
    <div class="drawer-header">
        <h2>Tekrar Hoş Geldin.</h2>
        <span class="close-drawer" onclick="closeAll()">&times;</span>
    </div>
    <form class="drawer-form" onsubmit="handleLogin(event)">
        <div class="input-group">
            <input type="email" name="email" placeholder="E-posta Adresi" required>
        </div>
        <div class="input-group">
            <input type="password" name="password" placeholder="Şifre" required>
        </div>
        <button type="submit" class="btn btn-full" style="background: var(--deep-purple); color: white;">Sisteme Giriş Yap</button>
        <p class="drawer-footer-text">Hesabın yok mu? <a href="javascript:void(0)" onclick="openRegister()">Kaydol</a></p>
    </form>
</div>

<!-- Kaydol Çekmecesi -->
<div class="drawer" id="registerDrawer">
    <div class="drawer-header">
        <h2>Yeni Sistem Kaydı.</h2>
        <span class="close-drawer" onclick="closeAll()">&times;</span>
    </div>
    <form class="drawer-form" onsubmit="handleRegister(event)">
        <div class="input-group">
            <input type="text" name="fullName" placeholder="Ad Soyad" required>
        </div>
        <div class="input-group">
            <input type="email" name="email" placeholder="E-posta Adresi" required>
        </div>
        <div class="input-group">
            <input type="password" name="password" placeholder="Şifre" required>
        </div>
        <button type="submit" class="btn btn-full" style="background: var(--deep-purple); color: white;">Kaydı Tamamla</button>
        <p class="drawer-footer-text">Zaten üye misin? <a href="javascript:void(0)" onclick="openLogin()">Giriş Yap</a></p>
    </form>
</div>

<!-- Sepetim Çekmecesi (Auth Seçenekleri Buraya Entegre Edildi) -->
<div class="drawer" id="cartDrawer" style="display: flex; flex-direction: column; height: 100vh;">
    <div class="drawer-header">
        <h2>Sepetim</h2>
        <span class="close-drawer" onclick="closeAll()">&times;</span>
    </div>
    
    <div id="cartItemsList" class="cart-items-container" style="flex: 1; overflow-y: auto; padding: 0 40px;">
        <p class="empty-cart-msg">Sepetiniz henüz boş.</p>
    </div>
    
    <div class="drawer-footer" id="cartFooter" style="display: none; padding: 20px 40px; border-top: 2.5px solid var(--mid-lila); background: white;">
        
        <!-- Dinamik Auth Paneli: Giriş yapılmamışsa burada görünür -->
        <div id="cartAuthSection" style="display: none; background: #fbf9ff; padding: 15px; border-radius: 20px; margin-bottom: 15px; border: 1px solid var(--soft-lila);">
            <p style="font-size: 12px; font-weight: 600; text-align: center; color: #777; margin-bottom: 10px;">Ödeme için bir yol seçin:</p>
            <div style="display: flex; gap: 10px;">
                <button onclick="openLogin()" style="flex: 1; padding: 10px; border-radius: 12px; border: 1px solid var(--deep-purple); background: white; color: var(--deep-purple); font-size: 11px; font-weight: 700; cursor: pointer;">GİRİŞ YAP</button>
                <button onclick="continueAsGuest()" style="flex: 1; padding: 10px; border-radius: 12px; border: none; background: var(--mid-lila); color: var(--deep-purple); font-size: 11px; font-weight: 700; cursor: pointer;">MİSAFİR DEVAM</button>
            </div>
        </div>

        <div id="totalPriceArea" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; font-family: 'Montserrat';">
            <span style="font-weight: 600; color: #777;">TOPLAM:</span>
            <span id="cartTotal" style="font-weight: 700; color: var(--accent-purple); font-size: 24px;">0 TL</span>
        </div>
        
        <!-- Bu buton sadece giriş yapılmışsa veya misafir seçilmişse Checkout Modal'ı açar -->
        <button id="cartCheckoutBtn" class="btn btn-full" onclick="openCheckout()" style="background: var(--deep-purple); color: white; border-radius: 15px; width: 100%;">
            Ödemeye Geç
        </button>
    </div>
</div>

<!-- Ürün Detay Modalı (Header Sabitlendi) -->
<div id="productDetailModal" class="checkout-modal" style="display:none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(255,255,255,0.98); z-index: 4000; align-items: flex-start; justify-content: center; backdrop-filter: blur(10px); overflow-y: auto;">
    <div class="checkout-content" style="width: 95%; max-width: 1200px; background: white; border-radius: 40px; position: relative; margin: 40px 0; box-shadow: 0 40px 100px rgba(0,0,0,0.1); overflow: hidden;">
        
        <!-- Sabit Header (image_a83515.jpg'deki eksiklik giderildi) -->
        <div style="position: sticky; top: 0; display: flex; justify-content: space-between; align-items: center; padding: 25px 50px; border-bottom: 1px solid #f8f1ff; background: rgba(255,255,255,0.9); backdrop-filter: blur(5px); z-index: 10;">
            <div style="font-family: 'Montserrat'; font-weight: 800; font-size: 24px; color: var(--deep-purple);">KOD.</div>
            <span class="close-checkout" onclick="closeProductDetail()" style="font-size: 40px; cursor: pointer; color: #ccc;">&times;</span>
        </div>

        <div id="productDetailBody" style="display: grid; grid-template-columns: 1fr 1fr; gap: 60px; padding: 50px;">
            <!-- Dinamik İçerik -->
        </div>

        <div style="padding: 50px; background: #fafafa; border-top: 1px solid #f0f0f0;">
            <h3 style="font-family: 'Montserrat'; font-weight: 700; margin-bottom: 30px; color: var(--text-main); font-size: 20px;">Benzer Algoritmalar</h3>
            <div id="similarProductsGrid" style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 25px;">
                <!-- Benzer Ürünler -->
            </div>
        </div>
    </div>
</div>

<!-- Ödeme Sayfası Modal (Checkout) -->
<div id="checkoutModal" class="checkout-modal" style="display:none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(255,255,255,0.98); z-index: 3000; align-items: center; justify-content: center; backdrop-filter: blur(10px);">
    <div class="checkout-content" style="width: 90%; max-width: 1000px; background: white; padding: 40px; border-radius: 30px; box-shadow: 0 30px 60px rgba(0,0,0,0.1); position: relative;">
        <div class="checkout-header" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px;">
            <h2 style="font-family: 'Montserrat'; font-weight: 700; color: var(--text-main);">Sipariş Detayları</h2>
            <span class="close-checkout" onclick="closeCheckout()" style="font-size: 40px; cursor: pointer; color: #ccc;">&times;</span>
        </div>
        
        <div id="checkoutMainBody" style="display: grid; grid-template-columns: 1.2fr 0.8fr; gap: 40px;">
            <div class="checkout-form-section">
                <h3 style="font-size: 18px; margin-bottom: 20px; color: #555;">Teslimat ve Ödeme</h3>
                <form id="orderForm" onsubmit="processOrder(event)" style="display: flex; flex-direction: column; gap: 15px;">
                    <input type="text" name="customerName" placeholder="Tam Adınız" required style="width: 100%; padding: 15px; border-radius: 12px; border: 1.5px solid #eee;">
                    <textarea name="address" placeholder="Teslimat Adresi" required style="width: 100%; height: 70px; padding: 15px; border-radius: 12px; border: 1.5px solid #eee; font-family: 'Poppins';"></textarea>
                    
                    <div class="payment-methods" style="margin: 10px 0;">
                        <p style="font-size: 14px; font-weight: 600; margin-bottom: 10px; color: #777;">Ödeme Yöntemi Seçin:</p>
                        <div style="display: flex; gap: 10px; flex-wrap: wrap;">
                            <label style="flex: 1; padding: 12px; border: 1.5px solid #eee; border-radius: 12px; cursor: pointer; font-size: 13px; text-align: center;">
                                <input type="radio" name="paymentMethod" value="Kart" checked style="margin-right: 5px;"> Kredi Kartı
                            </label>
                            <label style="flex: 1; padding: 12px; border: 1.5px solid #eee; border-radius: 12px; cursor: pointer; font-size: 13px; text-align: center;">
                                <input type="radio" name="paymentMethod" value="Havale" style="margin-right: 5px;"> Havale/EFT
                            </label>
                            <label style="flex: 1; padding: 12px; border: 1.5px solid #eee; border-radius: 12px; cursor: pointer; font-size: 13px; text-align: center;">
                                <input type="radio" name="paymentMethod" value="Kapıda" style="margin-right: 5px;"> Kapıda Ödeme
                            </label>
                        </div>
                    </div>

                    <div id="cardDetails" style="display: flex; gap: 10px;">
                        <input type="text" placeholder="Kart No" style="flex: 2; padding: 15px; border-radius: 12px; border: 1.5px solid #eee;">
                        <input type="text" placeholder="CVC" style="flex: 1; padding: 15px; border-radius: 12px; border: 1.5px solid #eee;">
                    </div>
                    
                    <button type="submit" class="btn btn-full" style="background: var(--deep-purple); color: white; padding: 18px; border-radius: 15px; border:none; font-weight: 600; cursor: pointer;">Siparişi Tamamla</button>
                </form>
            </div>

            <div class="checkout-summary-section" style="background: #fbf9ff; padding: 25px; border-radius: 25px; border: 1px solid var(--soft-lila);">
                <h3 style="font-size: 18px; margin-bottom: 20px; color: #555;">Sipariş Özeti</h3>
                <div id="checkoutSummaryList"></div>
                <hr style="border: 0; border-top: 1px solid #eee; margin: 20px 0;">
                <div style="display: flex; justify-content: space-between; align-items: center;">
                    <span style="font-weight: 600; color: #777;">TOPLAM:</span>
                    <span id="checkoutTotalText" style="font-weight: 700; color: var(--accent-purple); font-size: 24px;">0 TL</span>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .drawer {
        position: fixed;
        top: 0;
        right: -450px;
        width: 400px;
        height: 100%;
        background: white;
        z-index: 2001;
        box-shadow: -10px 0 30px rgba(0,0,0,0.1);
        transition: right 0.4s cubic-bezier(0.82, 0.01, 0.77, 0.41);
    }
    .drawer.active { right: 0; }
    .drawer-header { padding: 40px 40px 20px 40px; display: flex; justify-content: space-between; align-items: center; }
    .drawer-header h2 { font-family: 'Montserrat', sans-serif; font-size: 22px; font-weight: 600; color: var(--text-main); margin: 0; }
    .close-drawer { font-size: 32px; line-height: 1; cursor: pointer; color: #ccc; transition: 0.3s; display: flex; align-items: center; justify-content: center; width: 40px; height: 40px; border-radius: 50%; }
    .close-drawer:hover { color: var(--deep-purple); background: var(--soft-lila); }
    .drawer-form { display: flex; flex-direction: column; gap: 15px; padding: 0 40px; }
    .input-group input { width: 100%; padding: 15px; border-radius: 12px; border: 1.5px solid #eee; font-family: 'Poppins'; box-sizing: border-box; transition: 0.3s; }
    .input-group input:focus { border-color: var(--deep-purple); outline: none; background: var(--soft-lila); }
    .btn-full { width: 100%; padding: 16px; margin-top: 10px; border: none; cursor: pointer; font-family: 'Poppins'; font-weight: 600; transition: 0.3s; }
    .btn-full:hover { opacity: 0.9; transform: translateY(-2px); }
    .drawer-footer-text { font-size: 13px; color: #777; text-align: center; margin-top: 20px; }
    .drawer-footer-text a { color: var(--deep-purple); font-weight: 600; text-decoration: none; }
    .cart-items-container::-webkit-scrollbar { width: 5px; }
    .cart-items-container::-webkit-scrollbar-thumb { background: var(--mid-lila); border-radius: 10px; }
    .empty-cart-msg { color: #888; font-size: 14px; text-align: center; margin-top: 50px; font-family: 'Poppins'; }
</style>