<!-- AOS (Animate on Scroll) Animasyon Kütüphanesi -->
<script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>

<script>
    /**
     * KOD. İşletim Sistemi - Çekirdek Script Yazılımı v2.2 (İptal Talebi Mantığı)
     */

    // 1. Animasyon Motorunu Başlat
    if (typeof AOS !== 'undefined') { 
        AOS.init({ duration: 1000, once: true }); 
    }

    /* --- PANEL VE ÇEKMECE YÖNETİM SİSTEMİ --- */
    function closeAll() {
        const drawers = ['loginDrawer', 'registerDrawer', 'cartDrawer', 'accountDrawer'];
        drawers.forEach(id => {
            const el = document.getElementById(id);
            if(el) el.classList.remove('active');
        });
        const overlay = document.getElementById('overlay');
        if(overlay) {
            overlay.classList.remove('active');
            overlay.style.display = 'none'; 
        }
    }

    function openLogin() { 
        closeAll(); 
        const ov = document.getElementById('overlay');
        const dr = document.getElementById('loginDrawer');
        if(ov) { ov.style.display = 'block'; setTimeout(() => ov.classList.add('active'), 10); }
        if(dr) dr.classList.add('active'); 
    }

    function openRegister() { 
        closeAll(); 
        const ov = document.getElementById('overlay');
        const dr = document.getElementById('registerDrawer');
        if(ov) { ov.style.display = 'block'; setTimeout(() => ov.classList.add('active'), 10); }
        if(dr) dr.classList.add('active'); 
    }

    function openCart() { 
        closeAll(); 
        const ov = document.getElementById('overlay');
        const dr = document.getElementById('cartDrawer');
        if(ov) { ov.style.display = 'block'; setTimeout(() => ov.classList.add('active'), 10); }
        if(dr) dr.classList.add('active'); 
        updateCartDrawer(); 
    }
    
    function openAccount() { 
        closeAll(); 
        const ov = document.getElementById('overlay');
        const dr = document.getElementById('accountDrawer');
        if(ov) { ov.style.display = 'block'; setTimeout(() => ov.classList.add('active'), 10); }
        if(dr) dr.classList.add('active');
        populateAccountPage();
    }

    window.addEventListener('DOMContentLoaded', () => {
        const overlay = document.getElementById('overlay');
        if(overlay) overlay.onclick = closeAll;
    });

    /* --- AKILLI ARAMA MOTORU --- */
    function searchProducts() {
        const input = document.getElementById('searchInput').value.toLowerCase().trim();
        const cards = document.getElementsByClassName('product-card');
        for (let card of cards) {
            const name = card.getAttribute('data-name') || "";
            const type = card.getAttribute('data-type') || "";
            if (input === "" || name.toLowerCase().includes(input) || type.toLowerCase().includes(input)) {
                card.style.display = "flex"; 
            } else {
                card.style.display = "none";
            }
        }
    }

