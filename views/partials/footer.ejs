    /* --- ÜRÜN İNCELEME MODALI VE BENZER ALGORİTMALAR --- */
    function openProductDetail(productName) {
        const product = allProductsData.find(p => p.name === productName);
        if (!product) return;
        
        closeAll(); 

        document.getElementById('productDetailBody').innerHTML = `
            <div class="detail-image" data-aos="fade-right"><img src="/assets/${product.image}" style="width:100%; border-radius:20px;"></div>
            <div class="detail-info" data-aos="fade-left">
                <span style="color:var(--deep-purple); font-weight:700; font-size:12px; text-transform:uppercase; letter-spacing:1px;">${product.type}</span>
                <h2 style="font-family:'Montserrat'; margin:15px 0; font-size:28px; font-weight:800;">${product.name}</h2>
                <div style="font-size:24px; font-weight:700; color:var(--accent-purple); margin-bottom:20px;">${product.price} TL</div>
                <p style="color:#666; line-height:1.6;">${product.description}</p>
                <div style="display:flex; gap:20px; border-bottom:1px solid #eee; margin-bottom:15px; margin-top:20px;">
                    <button onclick="switchTab('specs')" id="tab-specs" style="background:none; border:none; padding-bottom:10px; border-bottom:2px solid var(--deep-purple); cursor:pointer; font-weight:600;">Özellikler</button>
                    <button onclick="switchTab('usage')" id="tab-usage" style="background:none; border:none; padding-bottom:10px; cursor:pointer; color:#999;">Kullanım</button>
                </div>
                <div id="tab-content" style="font-size:14px; color:#555; min-height:80px;">${product.details}</div>
                <button class="btn btn-full" onclick="addToCart('${product.name}', ${product.price}); closeProductDetail(); openCart();" style="background:var(--deep-purple); color:white; margin-top:30px; width:100%; border-radius:15px; cursor:pointer; font-weight:600; padding:18px;">Sepete Ekle</button>
            </div>
        `;

        const similarProducts = allProductsData.filter(p => p.name !== product.name).sort(() => 0.5 - Math.random()).slice(0, 4);
        const similarGrid = document.getElementById('similarProductsGrid');
        if(similarGrid) {
            similarGrid.innerHTML = similarProducts.map(p => `
                <div onclick="openProductDetail('${p.name}')" style="background:white; padding:15px; border-radius:20px; cursor:pointer; border:1px solid #f0f0f0; transition:0.3s; text-align:center;">
                    <img src="/assets/${p.image}" style="width:100%; height:120px; object-fit:contain; border-radius:12px; margin-bottom:10px;">
                    <div style="font-weight:600; font-size:12px; color:var(--text-main); height:35px; overflow:hidden;">${p.name}</div>
                    <div style="color:var(--accent-purple); font-weight:700; font-size:13px; margin-top:5px;">${p.price} TL</div>
                </div>
            `).join('');
        }

        document.getElementById('productDetailModal').style.display = 'flex';
        window.activeProduct = product;
    }

    function switchTab(type) {
        const content = document.getElementById('tab-content');
        if (!window.activeProduct || !content) return;
        if (type === 'specs') {
            content.innerText = window.activeProduct.details;
            document.getElementById('tab-specs').style.borderBottom = "2px solid var(--deep-purple)";
            document.getElementById('tab-specs').style.color = "#333";
            document.getElementById('tab-usage').style.borderBottom = "none";
            document.getElementById('tab-usage').style.color = "#999";
        } else {
            content.innerText = window.activeProduct.usage;
            document.getElementById('tab-usage').style.borderBottom = "2px solid var(--deep-purple)";
            document.getElementById('tab-usage').style.color = "#333";
            document.getElementById('tab-specs').style.borderBottom = "none";
            document.getElementById('tab-specs').style.color = "#999";
        }
    }

    function closeProductDetail() { document.getElementById('productDetailModal').style.display = 'none'; }

    /* --- SEPET YÖNETİMİ --- */
    let cart = JSON.parse(sessionStorage.getItem('myCart')) || []; 

    function handleCartClick(btn) {
        const name = btn.getAttribute('data-product-name');
        const price = btn.getAttribute('data-product-price');
        addToCart(name, price);
    }

    function addToCart(name, price) {
        const numericPrice = Number(price);
        if (isNaN(numericPrice)) return;
        cart.push({ name: name, price: numericPrice });
        sessionStorage.setItem('myCart', JSON.stringify(cart)); 
        updateCartDrawer();
    }

    function updateCartDrawer() {
        const list = document.getElementById('cartItemsList');
        const footer = document.getElementById('cartFooter');
        const badge1 = document.getElementById('cartCount');
        const badge2 = document.getElementById('modalCartCount');
        
        if(badge1) badge1.innerText = cart.length;
        if(badge2) badge2.innerText = cart.length;

        if (!list) return;
        if (cart.length === 0) {
            list.innerHTML = '<p class="empty-cart-msg">Sepetiniz boş.</p>';
            if(footer) footer.style.display = 'none';
        } else {
            list.innerHTML = cart.map((item, index) => `
                <div style="display:flex; justify-content:space-between; align-items:center; padding:15px 0; border-bottom:1px solid #f8f1ff;">
                    <div style="text-align: left;">
                        <span style="font-size:13px; font-weight:600; color:#333;">${item.name}</span>
                        <span style="font-size:12px; color:var(--accent-purple); display:block;">${item.price} TL</span>
                    </div>
                    <button onclick="removeFromCart(${index})" style="background:#fff0f0; color:#ff4d4d; border:none; width:28px; height:28px; border-radius:50%; cursor:pointer;">&times;</button>
                </div>
            `).join('');
            
            if(footer) {
                footer.style.display = 'block';
                document.getElementById('cartTotal').innerText = cart.reduce((t, i) => t + i.price, 0) + " TL";
                
                const user = JSON.parse(sessionStorage.getItem('loggedInUser'));
                const isGuest = sessionStorage.getItem('isGuest');
                const authSection = document.getElementById('cartAuthSection');
                const checkoutBtn = document.getElementById('cartCheckoutBtn');

                if(authSection && checkoutBtn) {
                    if (user || isGuest) {
                        authSection.style.display = 'none';
                        checkoutBtn.style.display = 'block';
                    } else {
                        authSection.style.display = 'block';
                        checkoutBtn.style.display = 'none';
                    }
                }
            }
        }
    }

    function removeFromCart(index) {
        cart.splice(index, 1);
        sessionStorage.setItem('myCart', JSON.stringify(cart));
        updateCartDrawer();
    }

    /* --- ÖDEME VE SİPARİŞ GEÇMİŞİ --- */
    function openCheckout() {
        const user = JSON.parse(sessionStorage.getItem('loggedInUser'));
        if (cart.length === 0) return;
        if (!user && !sessionStorage.getItem('isGuest')) { openLogin(); return; }
        
        closeAll();
        document.getElementById('checkoutModal').style.display = 'flex';
        const total = cart.reduce((t, i) => t + i.price, 0);
        document.getElementById('checkoutSummaryList').innerHTML = cart.map(i => `<div style="display:flex; justify-content:space-between; margin-bottom:10px;"><span>${i.name}</span><strong>${i.price} TL</strong></div>`).join('');
        document.getElementById('checkoutTotalText').innerText = total + " TL";
        if(user) document.getElementById('checkoutName').value = user.fullName;
    }

    function processOrder(event) {
        event.preventDefault();
        const user = JSON.parse(sessionStorage.getItem('loggedInUser'));
        const address = event.target.address.value;
        const totalAmount = cart.reduce((t, i) => t + i.price, 0);

        if (user) {
            localStorage.setItem('address_' + user.email, address);
            // Sipariş ilk oluşturulduğunda her zaman "Hazırlanıyor" başlar.
            const newOrder = {
                id: "#KOD-" + Math.floor(1000 + Math.random() * 9000),
                date: new Date().toLocaleDateString('tr-TR'),
                status: "Hazırlanıyor",
                items: [...cart],
                total: totalAmount
            };
            let history = JSON.parse(localStorage.getItem('history_' + user.email)) || [];
            history.unshift(newOrder);
            localStorage.setItem('history_' + user.email, JSON.stringify(history));
        }

        alert("🚀 Siparişiniz başarıyla alındı! Durumu 'Hesabım' panelinden görebilirsiniz.");
        cart = []; sessionStorage.removeItem('myCart'); location.reload();
    }

    /* --- SİPARİŞ İPTAL TALEBİ MANTIĞI --- */
    function cancelOrder(orderId) {
        if(!confirm(orderId + " numaralı siparişiniz için iptal talebi oluşturmak istediğinize emin misiniz?")) return;

        const user = JSON.parse(sessionStorage.getItem('loggedInUser'));
        if(!user) return;

        let history = JSON.parse(localStorage.getItem('history_' + user.email)) || [];
        const orderIndex = history.findIndex(o => o.id === orderId);

        if(orderIndex > -1) {
            // Anında silmek yerine durumu "İptal Talebi Alındı" yapıyoruz.
            history[orderIndex].status = "İptal Talebi Alındı";
            localStorage.setItem('history_' + user.email, JSON.stringify(history));
            
            alert("✅ İptal talebiniz sistemimize iletildi. Müşteri temsilcilerimiz en kısa sürede işleminizi sonuçlandıracaktır.");
            populateAccountPage(); // Sayfayı yenilemeden arayüzü anında güncelle
        }
    }

    /* --- HESABIM PANELİ VERİ YÖNETİMİ --- */
    function populateAccountPage() {
        const user = JSON.parse(sessionStorage.getItem('loggedInUser'));
        if(!user) return;
        document.getElementById('accName').innerText = user.fullName;
        document.getElementById('accEmail').innerText = user.email;
        document.getElementById('accAddress').innerText = localStorage.getItem('address_' + user.email) || "Henüz kayıtlı bir adres yok.";
        
        const history = JSON.parse(localStorage.getItem('history_' + user.email)) || [];
        const historyDiv = document.getElementById('orderHistoryList');
        if(history.length === 0) {
            historyDiv.innerHTML = '<p style="font-size:12px; color:#999; text-align:center;">İşlem kaydı yok.</p>';
        } else {
            historyDiv.innerHTML = history.map(order => {
                
                // İptal Butonu Görüntüleme Mantığı
                const canCancel = ["İşleniyor", "Hazırlanıyor"].includes(order.status);
                const cancelButton = canCancel ? 
                    `<button onclick="cancelOrder('${order.id}')" style="background:none; border:none; color:#ff5252; font-size:11px; font-weight:700; cursor:pointer; padding:0; text-decoration:underline;">İptal Talebi Oluştur</button>` : '';

                // Duruma Göre Renkli Etiket (Badge) Ayarı
                let statusBg = "var(--soft-lila)";
                let statusColor = "var(--deep-purple)";
                
                if(order.status === "İptal Talebi Alındı") {
                    statusBg = "#fff0f0";
                    statusColor = "#ff4d4d";
                } else if (order.status === "İptal Edildi") {
                    statusBg = "#f5f5f5";
                    statusColor = "#888";
                }

                return `
                <div style="background:#fff; border:1.5px solid #eee; padding:18px; border-radius:20px; margin-bottom:12px;">
                    <div style="display:flex; justify-content:space-between; margin-bottom:10px;">
                        <strong style="color:var(--deep-purple);">${order.id}</strong>
                        <span style="font-size:10px; padding:4px 8px; border-radius:8px; background:${statusBg}; color:${statusColor}; font-weight:700; text-transform:uppercase;">${order.status}</span>
                    </div>
                    <div style="font-size:11px; color:#999; margin-bottom:10px; display:flex; justify-content:space-between;">
                        <span>${order.date}</span>
                        ${cancelButton}
                    </div>
                    <div style="border-top:1px solid #f8f1ff; padding-top:10px;">
                        ${order.items.map(item => `
                            <div onclick="openProductDetail('${item.name}')" style="cursor:pointer; display:flex; justify-content:space-between; margin-bottom:5px; font-size:13px; color:#444;">
                                <span style="text-decoration:underline;">${item.name}</span>
                                <span style="font-weight:600;">${item.price} TL</span>
                            </div>
                        `).join('')}
                    </div>
                    <div style="text-align:right; margin-top:10px; font-weight:700; color:var(--accent-purple); font-size:16px;">${order.total.toLocaleString('tr-TR')} TL</div>
                </div>
            `}).join('');
        }
    }

    /* --- AUTH MANTIĞI --- */
    function handleRegister(event) {
        event.preventDefault();
        const newUser = { fullName: event.target.fullName.value, email: event.target.email.value, password: event.target.password.value };
        localStorage.setItem('registeredUser', JSON.stringify(newUser));
        alert("Kayıt başarılı! Giriş yapabilirsiniz."); 
        openLogin(); 
    }

    function handleLogin(event) {
        event.preventDefault();
        const storedUser = JSON.parse(localStorage.getItem('registeredUser'));
        if (storedUser && storedUser.email === event.target.email.value && storedUser.password === event.target.password.value) {
            sessionStorage.setItem('loggedInUser', JSON.stringify(storedUser));
            sessionStorage.removeItem('isGuest'); 
            location.reload();
        } else { alert("Hatalı giriş verisi!"); }
    }

    function updateUIForUser(name) {
        const nav = document.querySelector('nav');
        if(nav && !document.getElementById('profileBtn')) {
            nav.querySelectorAll('button.drawer-trigger').forEach(btn => btn.style.display = 'none');
            const firstName = name.split(' ')[0];
            const profileHtml = `<span id="profileBtn" class="drawer-trigger" onclick="openAccount()" style="color:var(--deep-purple); font-weight:700; cursor:pointer; text-transform:none; margin-right:15px;">Merhaba, ${firstName}</span><button class="drawer-trigger" onclick="logout()" style="cursor:pointer; background:none; border:none; color:#555; font-weight:600; text-transform:uppercase; font-size:11px;">Çıkış</button>`;
            const cartWrapper = nav.querySelector('.cart-wrapper');
            if(cartWrapper) cartWrapper.insertAdjacentHTML('beforebegin', profileHtml);
        }
    }

    function logout() { sessionStorage.removeItem('loggedInUser'); sessionStorage.removeItem('isGuest'); location.reload(); }
    function closeCheckout() { document.getElementById('checkoutModal').style.display = 'none'; }
    function continueAsGuest() { sessionStorage.setItem('isGuest', 'true'); updateCartDrawer(); }
    function toggleCardDetails() {
        const selected = document.querySelector('input[name="paymentMethod"]:checked');
        const details = document.getElementById('cardDetails');
        if(details) details.style.display = (selected && selected.value === 'Kart') ? 'flex' : 'none';
    }

    window.addEventListener('DOMContentLoaded', () => {
        const user = JSON.parse(sessionStorage.getItem('loggedInUser'));
        if (user) updateUIForUser(user.fullName);
        updateCartDrawer();
    });
</script>