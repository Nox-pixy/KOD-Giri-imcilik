<!-- AOS (Animate on Scroll) Animasyon Kütüphanesi -->
<script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>

<script>
    // 1. Animasyonları Başlat
    AOS.init({ duration: 1000, once: true });

    /* --- Çekmece (Panel) Yönetimi --- */
    function openLogin() { closeAll(); document.getElementById('overlay').classList.add('active'); document.getElementById('loginDrawer').classList.add('active'); }
    function openRegister() { closeAll(); document.getElementById('overlay').classList.add('active'); document.getElementById('registerDrawer').classList.add('active'); }
    function openCart() { closeAll(); document.getElementById('overlay').classList.add('active'); document.getElementById('cartDrawer').classList.add('active'); }
    
    function closeAll() {
        ['loginDrawer', 'registerDrawer', 'cartDrawer'].forEach(id => {
            const el = document.getElementById(id);
            if(el) el.classList.remove('active');
        });
        const overlay = document.getElementById('overlay');
        if(overlay) overlay.classList.remove('active');
    }

    if(document.getElementById('overlay')) {
        document.getElementById('overlay').onclick = closeAll;
    }

    /* --- Akıllı Arama Motoru --- */
    function searchProducts() {
        const input = document.getElementById('searchInput').value.toLowerCase().trim();
        const cards = document.getElementsByClassName('product-card');
        for (let card of cards) {
            const name = card.getAttribute('data-name') || "";
            const type = card.getAttribute('data-type') || "";
            card.style.display = (input === "" || name.includes(input) || type.includes(input)) ? "block" : "none";
        }
    }

    /* --- Fiyat Entegrasyonlu Sepet Yönetimi --- */
    let cart = []; 

    function handleCartClick(btn) {
        const name = btn.getAttribute('data-product-name');
        const price = btn.getAttribute('data-product-price');
        addToCart(name, price);
    }

    function addToCart(name, price) {
        const numericPrice = Number(price);
        if (isNaN(numericPrice)) {
            console.error("Geçersiz fiyat verisi!");
            return;
        }
        cart.push({ name: name, price: numericPrice });
        const badge = document.getElementById('cartCount');
        if(badge) {
            badge.innerText = cart.length;
            badge.style.transform = "scale(1.5)";
            setTimeout(() => badge.style.transform = "scale(1)", 200);
        }
        updateCartDrawer();
    }

    function updateCartDrawer() {
        const list = document.getElementById('cartItemsList');
        const footer = document.getElementById('cartFooter');
        const totalDisplay = document.getElementById('cartTotal'); 
        const authSection = document.getElementById('cartAuthSection');

        if (!list) return;
        if (cart.length === 0) {
            list.innerHTML = '<p class="empty-cart-msg">Sepetiniz henüz boş.</p>';
            if(footer) footer.style.display = 'none';
        } else {
            const totalAmount = cart.reduce((total, item) => total + item.price, 0);
            list.innerHTML = cart.map((item, index) => `
                <div style="display:flex; justify-content:space-between; align-items:center; padding:18px 0; border-bottom:1px solid #f8f1ff;">
                    <div style="text-align: left;">
                        <span style="font-size:14px; font-weight:600; display:block; color:var(--text-main); margin-bottom:4px;">${item.name}</span>
                        <span style="font-size:13px; color:var(--accent-purple); font-weight:700;">${item.price.toLocaleString('tr-TR')} TL</span>
                    </div>
                    <button onclick="removeFromCart(${index})" style="background: #fff0f0; color: #ff4d4d; border: none; width: 32px; height: 32px; border-radius: 50%; cursor: pointer;">&times;</button>
                </div>
            `).join('');
            
            if(footer) {
                footer.style.display = 'block';
                if(totalDisplay) totalDisplay.innerText = totalAmount.toLocaleString('tr-TR') + ' TL';
                
                // Kullanıcı giriş yapmamışsa seçim kısmını sepet içinde göster
                const user = JSON.parse(sessionStorage.getItem('loggedInUser'));
                if (authSection) authSection.style.display = user ? 'none' : 'block';
            }
        }
    }

    function removeFromCart(index) {
        cart.splice(index, 1);
        const badge = document.getElementById('cartCount');
        if(badge) badge.innerText = cart.length;
        updateCartDrawer();
    }

    /* --- ÜRÜN İNCELEME (DETAY) SİSTEMİ & BENZER ÜRÜNLER --- */
    function openProductDetail(productName) {
        // EJS verilerini globalden veya EJS'den çek
        const allProducts = <%- JSON.stringify(products) %>;
        const product = allProducts.find(p => p.name === productName);
        if (!product) return;

        // Modal içeriğini doldururken Header'ı manuel basmak yerine drawers.ejs'deki sabit yapıyı kullanıyoruz
        // Sadece Body kısmını güncelliyoruz
        document.getElementById('productDetailBody').innerHTML = `
            <div class="detail-image">
                <img src="/assets/${product.image}" alt="${product.name}" style="width:100%; border-radius:20px; box-shadow: 0 10px 30px rgba(0,0,0,0.05);">
            </div>
            <div class="detail-info" style="text-align:left;">
                <span style="color:var(--deep-purple); font-weight:700; font-size:12px; text-transform:uppercase; letter-spacing:1px;">${product.type}</span>
                <h2 style="font-family:'Montserrat'; margin:15px 0; font-size:28px; font-weight:700;">${product.name}</h2>
                <div style="font-size:24px; font-weight:700; color:var(--accent-purple); margin-bottom:20px;">${product.price} TL</div>
                <p style="color:#666; line-height:1.6; margin-bottom:25px;">${product.description || 'Açıklama bulunmuyor.'}</p>
                <div class="detail-tabs" style="display:flex; gap:20px; border-bottom:1px solid #eee; margin-bottom:15px;">
                    <button onclick="switchTab('specs')" id="tab-specs" style="background:none; border:none; padding-bottom:10px; border-bottom:2px solid var(--deep-purple); cursor:pointer; font-weight:600;">Özellikler</button>
                    <button onclick="switchTab('usage')" id="tab-usage" style="background:none; border:none; padding-bottom:10px; cursor:pointer; color:#999;">Kullanım</button>
                </div>
                <div id="tab-content" style="font-size:14px; color:#555; min-height:80px;">${product.details || 'Detay bilgisi yok.'}</div>
                <button class="btn btn-full" onclick="addToCart('${product.name}', ${product.price})" style="background:var(--deep-purple); color:white; margin-top:30px; width:100%; height:55px; border-radius:15px;">Sepete Ekle</button>
            </div>
        `;

        // Benzer Ürünler
        const similarProducts = allProducts.filter(p => p.type === product.type && p.name !== product.name).slice(0, 4);
        const similarGrid = document.getElementById('similarProductsGrid');
        if(similarGrid) {
            similarGrid.innerHTML = similarProducts.map(p => `
                <div onclick="openProductDetail('${p.name}')" style="background:white; padding:15px; border-radius:20px; cursor:pointer; border:1px solid #f0f0f0;">
                    <img src="/assets/${p.image}" style="width:100%; height:100px; object-fit:cover; border-radius:12px; margin-bottom:10px;">
                    <div style="font-weight:600; font-size:12px; color:var(--text-main);">${p.name}</div>
                    <div style="color:var(--accent-purple); font-weight:700; font-size:13px;">${p.price} TL</div>
                </div>
            `).join('');
        }

        document.getElementById('productDetailModal').style.display = 'flex';
        document.getElementById('productDetailModal').scrollTop = 0;
        window.activeProduct = product;
    }

    function switchTab(type) {
        const content = document.getElementById('tab-content');
        const specsBtn = document.getElementById('tab-specs');
        const usageBtn = document.getElementById('tab-usage');
        if (type === 'specs') {
            content.innerText = window.activeProduct.details;
            specsBtn.style.borderBottom = "2px solid var(--deep-purple)";
            specsBtn.style.color = "inherit";
            usageBtn.style.borderBottom = "none";
            usageBtn.style.color = "#999";
        } else {
            content.innerText = window.activeProduct.usage;
            usageBtn.style.borderBottom = "2px solid var(--deep-purple)";
            usageBtn.style.color = "inherit";
            specsBtn.style.borderBottom = "none";
            specsBtn.style.color = "#999";
        }
    }

    function closeProductDetail() {
        document.getElementById('productDetailModal').style.display = 'none';
    }

    /* --- ÖDEME SAYFASI (CHECKOUT) & AUTH KÖPRÜSÜ --- */
    function openCheckout() {
        const user = JSON.parse(sessionStorage.getItem('loggedInUser'));
        const isGuest = sessionStorage.getItem('isGuest');

        if (cart.length === 0) {
            alert("Önce sepetinize ürün eklemelisiniz.");
            return;
        }

        // Giriş yapılmamışsa VE misafir olarak devam edilmemişse sepeti açık tut ve uyar
        if (!user && !isGuest) {
            alert("Ödemeye geçmek için lütfen giriş yapın veya misafir olarak devam edin.");
            openCart();
            return;
        }

        closeAll();
        document.getElementById('checkoutModal').style.display = 'flex';
        updateCheckoutSummary();
    }

    function continueAsGuest() {
        sessionStorage.setItem('isGuest', 'true');
        document.getElementById('cartAuthSection').style.display = 'none';
        alert("Misafir olarak devam ediliyor. Şimdi 'Ödemeye Geç' butonuna basabilirsiniz.");
    }

    function updateCheckoutSummary() {
        const summaryList = document.getElementById('checkoutSummaryList');
        const totalText = document.getElementById('checkoutTotalText');
        summaryList.innerHTML = cart.map(item => `
            <div style="display:flex; justify-content:space-between; margin-bottom:12px; font-size:14px;">
                <span style="color:#555;">${item.name}</span>
                <span style="font-weight:600; color:var(--text-main);">${item.price.toLocaleString('tr-TR')} TL</span>
            </div>
        `).join('');
        const totalAmount = cart.reduce((total, item) => total + item.price, 0);
        totalText.innerText = totalAmount.toLocaleString('tr-TR') + ' TL';
    }

    function closeCheckout() {
        document.getElementById('checkoutModal').style.display = 'none';
    }

    function processOrder(event) {
        event.preventDefault();
        const user = JSON.parse(sessionStorage.getItem('loggedInUser'));
        const totalAmount = cart.reduce((total, item) => total + item.price, 0);
        
        alert("🚀 Siparişiniz başarıyla alındı! KOD ekibi sistem verilerini işlemeye başladı.");
        cart = [];
        const badge = document.getElementById('cartCount');
        if(badge) badge.innerText = "0";
        updateCartDrawer();
        closeCheckout();
        sessionStorage.removeItem('isGuest'); // Sipariş bitince misafir durumunu sıfırla
    }

    /* --- KULLANICI & HESABIM MANTIĞI --- */
    function handleLogin(event) {
        event.preventDefault();
        const emailInput = event.target.email.value;
        const passwordInput = event.target.password.value;
        const storedUser = JSON.parse(localStorage.getItem('registeredUser'));

        if (storedUser && storedUser.email === emailInput && storedUser.password === passwordInput) {
            sessionStorage.setItem('loggedInUser', JSON.stringify(storedUser));
            sessionStorage.removeItem('isGuest'); // Giriş yapılırsa misafirliği sil
            updateUIForUser(storedUser.fullName);
            closeAll();
            updateCartDrawer(); // Sepet içindeki auth panelini gizle
        } else {
            alert("E-posta veya şifre hatalı!");
        }
    }

    function updateUIForUser(name) {
        const loginLinks = document.querySelectorAll('a[onclick="openLogin()"]');
        loginLinks.forEach(link => {
            link.innerHTML = `<i class="bi bi-person-circle"></i> Hesabım`;
            link.setAttribute('onclick', 'showOrderHistory()');
        });
    }

    function logout() {
        sessionStorage.removeItem('loggedInUser');
        sessionStorage.removeItem('isGuest');
        location.reload();
    }

    window.addEventListener('DOMContentLoaded', () => {
        const user = JSON.parse(sessionStorage.getItem('loggedInUser'));
        if (user) updateUIForUser(user.fullName);
        updateCartDrawer();
    });
</script>