<!-- data-price eklendi: Filtreleme ve arama motoru için kritik -->
<div class="card product-card" 
     data-name="<%= product.name.toLowerCase() %>" 
     data-type="<%= product.type.toLowerCase() %>" 
     data-price="<%= product.price %>"
     data-aos="fade-up">
    
    <!-- Görsele tıklandığında detay modalını açar -->
    <div class="img-wrapper" onclick="openProductDetail('<%= product.name %>')" style="cursor: pointer;">
        <img src="/assets/<%= product.image %>" alt="<%= product.name %>">
        <div class="view-overlay">
            <span>İncele</span>
        </div>
    </div>

    <span class="product-type-label"><%= product.type %></span>
    
    <div class="name"><%= product.name %></div>

    <!-- Fiyat Alanı: Tasarıma uygun mor tonlarda -->
    <div class="price-container">
        <span class="price-value"><%= product.price %></span>
        <span class="price-currency">TL</span>
    </div>
    
    <p class="tagline">"<%= product.tagline %>"</p>
    
    <!-- HATASIZ BUTON: Tırnak işaretleri artık JS'i bozmuyor -->
    <button class="btn add-to-cart-btn" 
            data-product-name="<%= product.name %>" 
            data-product-price="<%= product.price %>"
            onclick="handleCartClick(this)">
        Sepete Ekle
    </button>
</div>

<style>
    .product-card {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: space-between;
        height: 100%;
        padding: 25px; 
        background: #fff;
        border-radius: 40px;
        border: 1px solid #f0f0f0;
        transition: 0.4s ease;
    }

    .product-card:hover {
        transform: translateY(-10px);
        box-shadow: 0 20px 40px rgba(0,0,0,0.05);
    }

    .product-type-label {
        font-size: 10px; 
        color: var(--deep-purple); 
        font-weight: 700; 
        letter-spacing: 1px;
        text-transform: uppercase;
        margin-top: 12px;
    }

    .card .name {
        font-weight: 600; 
        margin: 8px 0;
        font-size: 19px;
        color: var(--text-main);
        font-family: 'Montserrat', sans-serif;
    }

    .price-container {
        margin-bottom: 10px;
        color: var(--accent-purple);
    }
    .price-value {
        font-size: 22px;
        font-weight: 700;
    }
    .price-currency {
        font-size: 14px;
        font-weight: 600;
        margin-left: 2px;
    }

    .card .tagline {
        font-size: 12px; 
        color: #777; 
        margin-bottom: 20px;
        font-style: italic;
        min-height: 36px;
        display: flex;
        align-items: center;
        text-align: center;
        font-family: 'Poppins', sans-serif;
    }

    .img-wrapper {
        position: relative;
        width: 100%;
        height: 250px;
        border-radius: 20px;
        overflow: hidden;
        box-shadow: 0 10px 20px rgba(0,0,0,0.03);
    }

    /* İncele yazısı için overlay */
    .view-overlay {
        position: absolute;
        top: 0; left: 0; width: 100%; height: 100%;
        background: rgba(106, 27, 154, 0.2); /* var(--deep-purple) şeffaf hali */
        display: flex; align-items: center; justify-content: center;
        opacity: 0; transition: 0.3s;
    }
    .view-overlay span {
        color: white; background: var(--deep-purple);
        padding: 8px 20px; border-radius: 20px; font-size: 12px; font-weight: 600;
    }
    .img-wrapper:hover .view-overlay { opacity: 1; }

    .img-wrapper img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.6s cubic-bezier(0.165, 0.84, 0.44, 1);
    }

    .card:hover .img-wrapper img {
        transform: scale(1.08);
    }
</style>