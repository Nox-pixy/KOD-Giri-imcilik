<header>
    <!-- Logo Alanı -->
    <div class="logo-container">
        <a href="/">
            <img src="/assets/KOD urunler/logo.jpeg" alt="KOD Logo" class="main-logo">
        </a>
    </div>

    <!-- Minimalist Arama Çubuğu -->
    <div class="search-container">
        <div class="search-wrapper">
            <span class="search-icon">⚲</span>
            <input type="text" 
                   class="search-input" 
                   id="searchInput" 
                   placeholder="Sistemde ürün ara..." 
                   onkeyup="searchProducts()"
                   autocomplete="off">
        </div>
    </div>

    <!-- Sadece Kullanıcı ve Sepet -->
    <nav>
        <!-- Auth Butonları -->
        <button class="drawer-trigger" onclick="openLogin()">Giriş</button>
        <button class="drawer-trigger" onclick="openRegister()">Kaydol</button>
        
        <!-- Sepet İkonu ve Dinamik Sayaç -->
        <div class="cart-wrapper" onclick="openCart()">
            <span class="cart-icon">🛒</span>
            <span class="cart-badge" id="cartCount">0</span>
        </div>
    </nav>
</header>